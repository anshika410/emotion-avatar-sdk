{
  "name": "@anshika.t/avatar-sdk",
  "version": "0.0.2",
  "description": "Real-time animated avatar SDK with emotion detection and avatar rendering",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./models/*": "./dist/models/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-web": "^1.27.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "keywords": [
    "avatar",
    "animation",
    "emotion",
    "emotion-detection",
    "react",
    "real-time"
  ],
  "author": "Anshika-Tripathi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anshika.t/avatar-sdk.git"
  }
}